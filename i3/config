# i3 config file (v4)
# Jovan Lanik's i3 config 1.0
# www.github.com/jovanlanik
# clean and simple

set_from_resource $compositor i3.compositor false
set_from_resource $output1 i3.output.1 LVDS1
set_from_resource $output2 i3.output.2 LVDS1

exec ~/dotfiles/bg.sh
exec $compositor
exec dunst

default_border pixel 2
default_floating_border normal 2
hide_edge_borders both
gaps inner +4
gaps outer -4
font -windows-dina-medium-r-normal--10-80-96-96-c-70-iso8859-1
title_align center

client.focused #000000 #0c0c0c #f5f5f5 #000000 #000000
client.focused_inactive #0c0c0c #0c0c0c #f5f5f5 #000000 #000000
client.unfocused #000000 #0c0c0c #f5f5f5 #000000 #000000
client.urgent #000000 #0c0c0c #f5f5f5 #000000 #000000

set $mod mod4

set $terminal alacritty
set $browser apulse firefox
set $torrent transmission-gtk
set $modeling blender

set $wsn exec notify-send -t 300 workspace
set $ws0 "0"
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"

workspace $ws1 output $output1
workspace $ws2 output $output1
workspace $ws3 output $output1
workspace $ws4 output $output2
workspace $ws5 output $output2
workspace $ws6 output $output2

floating_modifier $mod

bindsym $mod+t exec $terminal
bindsym $mod+b exec $browser
bindsym $mod+c exec $torrent
bindsym $mod+m exec $modeling
bindsym $mod+r exec gtk3-widget-factory

bindsym $mod+v exec ~/dotfiles/swap.sh

mode $drag {
	bindsym --whole-window button1 mark swap; mode $drop
	bindsym --whole-window button2 exec exit
	bindsym --whole-window button3 exec exit
}

mode $drop {
	bindsym --whole-window button1 swap container with mark swap; unmark swap
	bindsym --whole-window button2 exec exit
	bindsym --whole-window button3 exec exit
}

bindsym $mod+q kill
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right
bindsym $mod+f fullscreen
bindsym $mod+s split h
bindsym $mod+d split v
bindsym $mod+grave workspace $ws0;$wsn $ws0
bindsym $mod+1 workspace $ws1;$wsn $ws1
bindsym $mod+2 workspace $ws2;$wsn $ws2
bindsym $mod+3 workspace $ws3;$wsn $ws3
bindsym $mod+4 workspace $ws4;$wsn $ws4
bindsym $mod+5 workspace $ws5;$wsn $ws5
bindsym $mod+6 workspace $ws6;$wsn $ws6

bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right
bindsym $mod+Shift+f floating toggle
bindsym $mod+Shift+s layout splith
bindsym $mod+Shift+d layout splitv
bindsym $mod+Shift+grave move container to workspace $ws0
bindsym $mod+Shift+1 move container to workspace $ws1
bindsym $mod+Shift+2 move container to workspace $ws2
bindsym $mod+Shift+3 move container to workspace $ws3
bindsym $mod+Shift+4 move container to workspace $ws4
bindsym $mod+Shift+5 move container to workspace $ws5
bindsym $mod+Shift+6 move container to workspace $ws6

bindsym $mod+Shift+r restart
bindsym $mod+Shift+e exit

