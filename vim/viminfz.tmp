"1	LINE	0
		<datalist id="timezones">
	<?php
		$zones = array_merge(
			glob("/usr/share/zoneinfo/*"),
			glob("/usr/share/zoneinfo/*/*")
			);
		$zones = array_filter($zones, 'is_file');
		$i = 0;
		$newZones = Array();
		foreach($zones as $zone)
		{
			$s = explode('/', $zone);
			$newZones[$i] = end($s);
			$i++;
		}
		sort($newZones);
		$zones = $newZones;
		$zones = array_unique($zones);
		$zones = preg_grep('/^[A-Z].*/', $zones);
		$zones = str_replace('_', ' ', $zones);
		foreach($zones as $zone)
		{
			echo("<option value=\"".$zone."\">\n");
		}
	?>
		</datalist>
